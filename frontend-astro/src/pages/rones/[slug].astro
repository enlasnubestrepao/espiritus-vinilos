---
import Base from '../../layouts/Base.astro'
import { rumSlug } from '../../utils/slugify.js'
import '../../styles/global.css'

export async function getStaticPaths() {
  const apiUrl = import.meta.env.VITE_API_URL || 'https://espiritus-vinilos.onrender.com'
  const res = await fetch(`${apiUrl}/api/rums/`)
  if (!res.ok) return []
  const rums = await res.json()

  return rums.map((rum) => ({
    params: { slug: rumSlug(rum) },
    props: { rum, allRums: rums },
  }))
}

const { rum, allRums } = Astro.props

// Recommendations: same type or country, excluding current, max 4
const related = allRums
  .filter(r => !(r.brand === rum.brand && r.name === rum.name))
  .filter(r => r.type === rum.type || r.country === rum.country)
  .slice(0, 4)

function formatPrice(price: string, currency: string) {
  if (!price) return null
  const num = parseFloat(price)
  if (currency === 'COP') return `$${num.toLocaleString('es-CO')} COP`
  if (currency === 'USD') return `$${num.toLocaleString('en-US')} USD`
  return `${num} ${currency}`
}

const title = `${rum.brand} ${rum.name} | En Las Nubes Trepao`
const description = [rum.type, rum.abv ? `${rum.abv}% ABV` : null, rum.country, rum.region].filter(Boolean).join(' · ')
const ogImage = rum.cover_url || 'https://enlasnubestrepao.com/og-image.jpg'
---

<Base title={title} description={description} ogImage={ogImage}>

  <!-- ── HERO ─────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-bg" style="background-image: url('/hero-1.png')"></div>
    {rum.cover_url && (
      <div
        class="hero-bg-cover"
        style={`background-image: url('${rum.cover_url}')`}
      ></div>
    )}
    <div class="hero-gradient"></div>

    <header class="site-header">
      <a href="/" class="site-logo">En Las Nubes Trepao</a>
      <a href="/" class="site-back">← Volver al catálogo</a>
    </header>

    <div class="hero-content">
      <!-- Botella flotante -->
      {rum.cover_url && (
        <div class="hero-bottle-wrap">
          <img
            class="hero-bottle"
            src={rum.cover_url}
            alt={`${rum.brand} ${rum.name}`}
            width="160" height="320"
            loading="eager"
          />
          {rum.scale && (
            <div class="hero-score">
              <span class="hero-score-val">{rum.scale}</span>
              <span class="hero-score-max">/5</span>
              <span class="hero-score-label">ENLT</span>
            </div>
          )}
        </div>
      )}

      <div class="hero-info">
        <p class="type">{rum.type}{rum.country ? ` · ${rum.country}` : ''}</p>
        <h1 class="name">
          <span class="brand">{rum.brand}</span>
          {rum.name && <span class="version">{rum.name}</span>}
        </h1>
        {rum.region && <p class="region">{rum.region}</p>}

        <div class="hero-pills">
          {rum.abv && <span class="pill">{rum.abv}% ABV</span>}
          {(rum.age_low || rum.age_max) && (
            <span class="pill">
              {rum.age_low === rum.age_max
                ? `${rum.age_low} años`
                : `${rum.age_low ?? '?'}–${rum.age_max ?? '?'} años`}
            </span>
          )}
          {rum.blend === 'Si' && <span class="pill">Blend</span>}
          {rum.terminado && <span class="pill pill-done">🫗 Terminado</span>}
        </div>

        {rum.buy_url && (
          <div class="hero-buy">
            {rum.buy_price && (
              <span class="buy-price">{formatPrice(rum.buy_price, rum.buy_currency)}</span>
            )}
            {rum.buy_availability && (
              <span class={`buy-avail ${rum.buy_availability?.toLowerCase().includes('stock') ? 'in-stock' : ''}`}>
                {rum.buy_availability}
              </span>
            )}
            <a class="btn btn-buy" href={rum.buy_url} target="_blank" rel="noopener">
              Ver precio ↗
            </a>
          </div>
        )}
      </div>
    </div>
  </section>

  <main class="page">

    <!-- ── META ──────────────────────────────────────────────── -->
    <section class="meta-section">
      <dl class="meta">
        {rum.abv      && <><dt>ABV</dt><dd>{rum.abv}%</dd></>}
        {rum.country  && <><dt>País</dt><dd>{rum.country}</dd></>}
        {rum.region   && <><dt>Región</dt><dd>{rum.region}</dd></>}
        {rum.blend    && <><dt>Blend</dt><dd>{rum.blend}</dd></>}
        {(rum.age_low || rum.age_max) && (
          <>
            <dt>Años</dt>
            <dd>{rum.age_low === rum.age_max ? rum.age_low : `${rum.age_low ?? '?'} – ${rum.age_max ?? '?'}`}</dd>
          </>
        )}
        {rum.terminado && <><dt>Estado</dt><dd class="terminado">Terminado</dd></>}
      </dl>

      {rum.url && (
        <a class="cta-card" href={rum.url} target="_blank" rel="noopener">
          <span class="cta-icon">🔗</span>
          <span class="cta-text">
            <span class="cta-title">Más información</span>
            <span class="cta-desc">Ficha técnica y detalles del productor</span>
          </span>
          <span class="cta-arrow">↗</span>
        </a>
      )}
    </section>

    <!-- ── RECOMENDACIONES ───────────────────────────────────── -->
    {related.length > 0 && (
      <section class="related">
        <h3 class="related-heading">
          Más de la colección · {rum.type || rum.country}
        </h3>
        <div class="related-grid">
          {related.map(r => (
            <a href={`/rones/${rumSlug(r)}/`} class="related-card">
              {r.cover_url
                ? <img
                    class="related-cover"
                    src={r.cover_url}
                    alt={`${r.brand} ${r.name}`}
                    width="140" height="200"
                    loading="lazy"
                  />
                : <div class="related-no-cover">🥃</div>
              }
              <div class="related-info">
                <span class="related-brand">{r.brand}</span>
                <span class="related-name">{r.name}</span>
                {r.abv && <span class="related-meta">{r.abv}% ABV</span>}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

  </main>
</Base>

<style>
  /* ── Header overlaid ─────────────────────────────────────── */
  .site-header {
    position: absolute;
    top: 0; left: 0; right: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 32px;
    background: linear-gradient(to bottom, rgba(10,10,10,.7) 0%, transparent 100%);
  }
  .site-logo {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    color: #fff;
    text-decoration: none;
    text-shadow: 0 1px 6px rgba(0,0,0,.6);
  }
  .site-back {
    font-size: 0.78rem;
    color: rgba(255,255,255,.72);
    text-decoration: none;
    transition: color .15s;
  }
  .site-back:hover { color: #fff; }

  /* ── Hero ────────────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 420px;
    background: var(--bg);
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute; inset: 0;
    background-size: cover;
    background-position: center 30%;
    filter: blur(0px) saturate(1.2);
    opacity: .5;
  }
  .hero-bg-cover {
    position: absolute; inset: 0;
    background-size: cover;
    background-position: center;
    filter: blur(48px) saturate(1.8) brightness(.6);
    transform: scale(1.12);
    opacity: .3;
  }
  .hero-gradient {
    position: absolute; inset: 0;
    background: linear-gradient(
      to top,
      #0a0a0a 0%,
      rgba(10,10,10,.7) 50%,
      rgba(10,10,10,.1) 100%
    );
  }
  .hero-content {
    position: relative; z-index: 1;
    display: flex;
    align-items: flex-end;
    gap: 36px;
    padding: 90px 40px 40px;
    width: 100%;
    max-width: 960px;
    margin: 0 auto;
    box-sizing: border-box;
  }

  /* Botella */
  .hero-bottle-wrap {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }
  .hero-bottle {
    height: 220px;
    width: auto;
    max-width: 120px;
    object-fit: contain;
    object-position: center bottom;
    filter: drop-shadow(0 12px 32px rgba(0,0,0,.8));
    display: block;
  }
  .hero-score {
    text-align: center;
    line-height: 1;
  }
  .hero-score-val {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    color: var(--ru-acc2);
  }
  .hero-score-max { font-size: 1rem; color: var(--text3); }
  .hero-score-label {
    display: block;
    font-size: 0.58rem;
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--text3);
    margin-top: 2px;
  }

  /* Info */
  .hero-info { flex: 1; min-width: 0; }
  .type {
    font-size: 0.7rem;
    color: var(--ru-acc);
    text-transform: uppercase;
    letter-spacing: .12em;
    margin-bottom: 10px;
  }
  .name {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 700;
    line-height: 1.08;
    color: #fff;
    margin-bottom: 6px;
    text-shadow: 0 2px 10px rgba(0,0,0,.5);
  }
  .brand { display: block; }
  .version { font-weight: 400; color: rgba(255,255,255,.65); font-size: .75em; }
  .region {
    font-size: 0.8rem;
    color: rgba(255,255,255,.5);
    margin-bottom: 14px;
  }

  /* Pills */
  .hero-pills { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 20px; }
  .pill {
    font-size: .65rem;
    font-weight: 600;
    padding: 3px 9px;
    border-radius: 10px;
    background: rgba(255,255,255,.1);
    color: rgba(255,255,255,.75);
    border: 1px solid rgba(255,255,255,.15);
  }
  .pill-done {
    background: rgba(181,101,29,.15);
    border-color: rgba(181,101,29,.3);
    color: var(--ru-acc2);
  }

  /* Buy box en hero */
  .hero-buy {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    background: rgba(0,0,0,.35);
    border: 1px solid rgba(255,255,255,.1);
    border-radius: 10px;
    padding: 10px 14px;
    backdrop-filter: blur(8px);
    max-width: 400px;
  }
  .buy-price {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--ru-acc2);
  }
  .buy-avail {
    font-size: .72rem;
    color: var(--text3);
    flex: 1;
  }
  .in-stock { color: #1DB954; }
  .btn {
    padding: 7px 14px;
    border-radius: 7px;
    font-size: 0.78rem;
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    transition: opacity .15s, transform .1s;
  }
  .btn:hover { opacity: .85; transform: translateY(-1px); }
  .btn-buy { background: var(--ru-acc2); color: #000; }

  /* ── Page body ───────────────────────────────────────────── */
  .page {
    max-width: 900px;
    margin: 0 auto;
    padding: 40px 32px 80px;
  }

  /* ── Meta ────────────────────────────────────────────────── */
  .meta-section {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 52px;
  }
  .meta {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 8px 20px;
    font-size: 0.83rem;
    padding: 16px 20px;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: var(--r);
  }
  .meta dt { color: var(--text3); }
  .meta dd { color: var(--text); }
  .terminado { color: var(--ru-acc); }

  /* CTA card */
  .cta-card {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    background: rgba(255,255,255,.04);
    border: 1px solid var(--border);
    border-radius: 10px;
    text-decoration: none;
    transition: background .15s, border-color .15s;
  }
  .cta-card:hover {
    background: rgba(255,255,255,.08);
    border-color: rgba(255,255,255,.18);
  }
  .cta-icon { font-size: 1rem; flex-shrink: 0; }
  .cta-text { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 1px; }
  .cta-title { font-size: .78rem; font-weight: 600; color: var(--text); }
  .cta-desc  { font-size: .65rem; color: var(--text3); }
  .cta-arrow {
    font-size: .78rem;
    color: var(--text3);
    flex-shrink: 0;
    transition: color .15s, transform .15s;
  }
  .cta-card:hover .cta-arrow { color: var(--text2); transform: translate(2px, -2px); }

  /* ── Recomendaciones ─────────────────────────────────────── */
  .related {
    border-top: 1px solid var(--border);
    padding-top: 32px;
  }
  .related-heading {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: .13em;
    color: var(--text3);
    margin-bottom: 20px;
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .related-card {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: transform .2s;
  }
  .related-card:hover { transform: translateY(-4px); }
  .related-cover {
    width: 100%;
    aspect-ratio: 2/3;
    object-fit: contain;
    object-position: center bottom;
    border-radius: 6px;
    display: block;
    filter: drop-shadow(0 6px 16px rgba(0,0,0,.6));
    transition: filter .2s;
    background: var(--bg3);
  }
  .related-card:hover .related-cover { filter: drop-shadow(0 10px 24px rgba(0,0,0,.8)); }
  .related-no-cover {
    width: 100%;
    aspect-ratio: 2/3;
    background: var(--bg3);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
  }
  .related-info { display: flex; flex-direction: column; gap: 2px; }
  .related-brand { font-size: .78rem; font-weight: 700; color: var(--text); }
  .related-name  { font-size: .72rem; color: var(--text2); }
  .related-meta  { font-size: .65rem; color: var(--text3); }

  /* ── Mobile ──────────────────────────────────────────────── */
  @media (max-width: 680px) {
    .site-header { padding: 14px 20px; }
    .hero { min-height: 360px; }
    .hero-content {
      padding: 72px 20px 28px;
      gap: 20px;
      align-items: flex-end;
    }
    .hero-bottle { height: 160px; }
    .name { font-size: 1.6rem; }
    .page { padding: 28px 20px 60px; }
    .related-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
  }
</style>
