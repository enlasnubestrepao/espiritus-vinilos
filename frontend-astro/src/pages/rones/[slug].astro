---
import Base from '../../layouts/Base.astro'
import { rumSlug } from '../../utils/slugify.js'

export async function getStaticPaths() {
  const apiUrl = import.meta.env.VITE_API_URL || 'https://espiritus-vinilos.onrender.com'
  const res = await fetch(`${apiUrl}/api/rums/`)
  if (!res.ok) return []
  const rums = await res.json()

  return rums.map((rum, index) => ({
    params: { slug: rumSlug(rum) },
    props: { rum, index },
  }))
}

const { rum } = Astro.props

const title = `${rum.brand} ${rum.name} | En Las Nubes Trepao`
const description = [
  rum.type,
  rum.abv ? `${rum.abv}% ABV` : null,
  rum.country,
  rum.region,
].filter(Boolean).join(' · ')

const ogImage = rum.cover_url || 'https://enlasnubestrepao.com/og-image.jpg'

function formatPrice(price, currency) {
  if (!price) return null
  const num = parseFloat(price)
  if (currency === 'COP') return `$${num.toLocaleString('es-CO')} COP`
  if (currency === 'USD') return `$${num.toLocaleString('en-US')} USD`
  return `${num} ${currency}`
}
---

<Base
  title={title}
  description={description || undefined}
  ogImage={ogImage}
>
  <main class="page">
    <a class="back" href="/">&larr; Volver al catálogo</a>

    <article class="spirit">
      <div class="cover-wrap">
        {rum.cover_url && (
          <img
            class="cover"
            src={rum.cover_url}
            alt={`${rum.brand} ${rum.name}`}
            width="280"
            height="420"
            loading="eager"
          />
        )}
        {rum.scale && (
          <div class="scale">
            <span class="scale-label">Puntuación ENLT</span>
            <span class="scale-value">{rum.scale}<span class="scale-max">/5</span></span>
          </div>
        )}
      </div>

      <div class="info">
        <p class="type">{rum.type}{rum.origin ? ` · ${rum.origin}` : ''}</p>
        <h1 class="name">{rum.brand} <span class="version">{rum.name}</span></h1>

        <dl class="meta">
          {rum.abv && <><dt>ABV</dt><dd>{rum.abv}%</dd></>}
          {rum.country && <><dt>País</dt><dd>{rum.country}</dd></>}
          {rum.region && <><dt>Región</dt><dd>{rum.region}</dd></>}
          {rum.blend && <><dt>Blend</dt><dd>{rum.blend}</dd></>}
          {(rum.age_low || rum.age_max) && (
            <>
              <dt>Años</dt>
              <dd>{rum.age_low === rum.age_max ? rum.age_low : `${rum.age_low ?? '?'} – ${rum.age_max ?? '?'}`}</dd>
            </>
          )}
          {rum.terminado && <><dt>Estado</dt><dd class="terminado">Terminado</dd></>}
        </dl>

        {rum.buy_url && (
          <div class="buy-box">
            {rum.buy_price && (
              <span class="buy-price">{formatPrice(rum.buy_price, rum.buy_currency)}</span>
            )}
            {rum.buy_availability && (
              <span class="buy-availability">{rum.buy_availability}</span>
            )}
            <a class="btn btn-buy" href={rum.buy_url} target="_blank" rel="noopener">
              Ver precio
            </a>
          </div>
        )}

        <div class="links">
          {rum.url && (
            <a class="btn btn-ref" href={rum.url} target="_blank" rel="noopener">
              Más info
            </a>
          )}
        </div>
      </div>
    </article>
  </main>
</Base>

<style>
  .page {
    max-width: 820px;
    margin: 0 auto;
    padding: 32px 20px 60px;
    color: var(--text);
  }

  .back {
    display: inline-block;
    color: var(--text2);
    text-decoration: none;
    font-size: 0.85rem;
    margin-bottom: 32px;
    transition: color .15s;
  }
  .back:hover { color: var(--text); }

  .spirit {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 36px;
    align-items: start;
  }

  @media (max-width: 620px) {
    .spirit { grid-template-columns: 1fr; }
    .cover-wrap { max-width: 180px; }
  }

  .cover-wrap {
    position: sticky;
    top: 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .cover {
    width: 100%;
    height: auto;
    border-radius: 6px;
    display: block;
    box-shadow: 0 8px 32px rgba(0,0,0,.5);
  }

  .scale {
    text-align: center;
  }
  .scale-label {
    display: block;
    font-size: 0.65rem;
    color: var(--text3);
    text-transform: uppercase;
    letter-spacing: .08em;
    margin-bottom: 2px;
  }
  .scale-value {
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--ru-acc2);
  }
  .scale-max { font-size: 1rem; color: var(--text3); }

  .type {
    font-size: 0.75rem;
    color: var(--ru-acc);
    text-transform: uppercase;
    letter-spacing: .08em;
    margin-bottom: 8px;
  }

  h1.name {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.5vw, 2.2rem);
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 24px;
  }
  .version { color: var(--text2); font-weight: 400; }

  .meta {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 6px 16px;
    font-size: 0.85rem;
    margin-bottom: 24px;
  }
  .meta dt { color: var(--text3); }
  .meta dd { color: var(--text); }
  .terminado { color: var(--ru-acc); }

  .buy-box {
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 14px 16px;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .buy-price { font-size: 1.1rem; font-weight: 700; color: var(--ru-acc2); }
  .buy-availability { font-size: 0.78rem; color: var(--text2); flex: 1; }

  .links { display: flex; gap: 10px; flex-wrap: wrap; }

  .btn {
    padding: 7px 16px;
    border-radius: 6px;
    font-size: 0.82rem;
    font-weight: 600;
    text-decoration: none;
    transition: opacity .15s;
    display: inline-block;
  }
  .btn:hover { opacity: .8; }
  .btn-buy { background: var(--ru-acc2); color: #000; }
  .btn-ref { background: var(--bg4); color: var(--text); border: 1px solid var(--border); }
</style>
