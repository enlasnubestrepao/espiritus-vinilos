---
import Base from '../../layouts/Base.astro'
import { vinylSlug } from '../../utils/slugify.js'
import '../../styles/global.css'

export async function getStaticPaths() {
  const apiUrl = import.meta.env.VITE_API_URL || 'https://espiritus-vinilos.onrender.com'
  const res = await fetch(`${apiUrl}/api/vinyls/`)
  if (!res.ok) return []
  const vinyls = await res.json()

  return vinyls.map((vinyl) => ({
    params: { slug: vinylSlug(vinyl) },
    props: { vinyl, allVinyls: vinyls },
  }))
}

const { vinyl, allVinyls } = Astro.props

// Recommendations: same genre or agrupador, excluding current, max 4
const related = allVinyls
  .filter(v => !(v.artista === vinyl.artista && v.album === vinyl.album))
  .filter(v => v.genero === vinyl.genero || v.agrupador === vinyl.agrupador)
  .slice(0, 4)

// Notes: split into paragraphs
const noteParagraphs = vinyl.notes
  ? vinyl.notes.split('\n\n').map((p: string) => p.trim()).filter(Boolean)
  : []

function creditIcon(role: string): string {
  const r = role.toLowerCase()
  if (/vocal|singer|lead vocal|voice|chorus|choir/.test(r))      return '🎤'
  if (/guitar|bajo|bass(?! drum)|cuatro|tres|banjo/.test(r))     return '🎸'
  if (/piano|keyboard|organ|wurlitzer|rhodes|clavinet/.test(r))  return '🎹'
  if (/drum|percussion|timbal|conga|bongo|timbale/.test(r))      return '🥁'
  if (/trumpet|trompeta|trombone|trombón|horn|tuba/.test(r))     return '🎺'
  if (/saxophone|saxo|flute|flauta|clarinet|oboe/.test(r))       return '🎷'
  if (/violin|viola|cello|string|cuerdas/.test(r))               return '🎻'
  if (/arranger|arreglo|arrange/.test(r))                        return '🎼'
  if (/producer|producid|executive producer/.test(r))            return '🎛'
  if (/engineer|ingenier|mixed|mastered|mezcla/.test(r))         return '🎚'
  if (/written|wrote|composed|compositor|author|letra/.test(r))  return '✍️'
  if (/photo|fotograf|design|art direction|artwork/.test(r))     return '🎨'
  return '🎵'
}

const title = `${vinyl.artista} — ${vinyl.album} | En Las Nubes Trepao`
const description = [vinyl.genero, vinyl.anio, vinyl.pais, vinyl.sello].filter(Boolean).join(' · ')
const ogImage = vinyl.cover_url || 'https://enlasnubestrepao.com/hero-1.png'
const ogImageAlt = `Tapa del disco ${vinyl.album} de ${vinyl.artista}`
---

<Base title={title} description={description} ogImage={ogImage} ogImageAlt={ogImageAlt} ogType="music.album">

  <!-- ── HERO ─────────────────────────────────────────────────── -->
  <section class="hero">
    <!-- Blurred cover as background -->
    {vinyl.cover_url && (
      <div
        class="hero-bg"
        style={`background-image: url('${vinyl.cover_url}')`}
      ></div>
    )}
    <!-- Dark gradient overlay -->
    <div class="hero-gradient"></div>

    <!-- Header overlaid on hero -->
    <header class="site-header">
      <a href="/" class="site-logo">En Las Nubes Trepao</a>
      <a href="/" class="site-back">← Volver al catálogo</a>
    </header>

    <!-- Hero content -->
    <div class="hero-content">
      <div class="hero-cover-wrap">
        {vinyl.cover_url
          ? <img
              class="hero-cover"
              src={vinyl.cover_url}
              alt={`${vinyl.album} — ${vinyl.artista}`}
              width="220" height="220"
              loading="eager"
            />
          : <div class="hero-cover-placeholder">🎵</div>
        }
      </div>
      <div class="hero-info">
        <p class="genre">{vinyl.genero}{vinyl.agrupador ? ` · ${vinyl.agrupador}` : ''}</p>
        <h1 class="album">{vinyl.album}</h1>
        <h2 class="artist">{vinyl.artista}</h2>
        <div class="hero-links">
          {vinyl.url && (
            <a class="btn btn-discogs" href={vinyl.url} target="_blank" rel="noopener">🔗 Discogs</a>
          )}
        </div>
      </div>
    </div>
  </section>

  <main class="page">

    <!-- ── NOTAS EDITORIALES (centerpiece) ──────────────────── -->
    {noteParagraphs.length > 0 && (
      <section class="notes-section">
        <span class="notes-label">Notas editoriales</span>
        <div class="notes-body">
          <span class="notes-mark">❝</span>
          {noteParagraphs.map((para, i) => (
            <p class={i === 0 ? 'notes-lead' : 'notes-p'}>{para}</p>
          ))}
        </div>
      </section>
    )}

    <!-- ── META + SPOTIFY EMBED ──────────────────────────────── -->
    <div class="meta-spotify-wrap">
      <dl class="meta">
        {vinyl.anio    && <><dt>Año</dt><dd>{vinyl.anio}</dd></>}
        {vinyl.pais    && <><dt>País</dt><dd>{vinyl.pais}</dd></>}
        {vinyl.sello   && <><dt>Sello</dt><dd>{vinyl.sello}{vinyl.pais_sello ? ` (${vinyl.pais_sello})` : ''}</dd></>}
        {vinyl.cat_num && <><dt>Catálogo</dt><dd>{vinyl.cat_num}</dd></>}
        {vinyl.origen  && <><dt>Origen</dt><dd>{vinyl.origen}</dd></>}
      </dl>
      {vinyl.spotify_id && (
        <div class="spotify-embed">
          <iframe
            src={`https://open.spotify.com/embed/album/${vinyl.spotify_id}?utm_source=generator&theme=0`}
            width="100%"
            height="152"
            frameborder="0"
            allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
            loading="lazy"
          ></iframe>
        </div>
      )}
    </div>

    <!-- ── TRACKLIST ─────────────────────────────────────────── -->
    {vinyl.tracks && vinyl.tracks.length > 0 && (
      <section class="tracklist">
        <h3>Tracklist</h3>
        <ol>
          {vinyl.tracks.map((t) => (
            <li>
              <span class="track-pos">{t.position}</span>
              <span class="track-title">{t.title}</span>
              {t.duration && <span class="track-dur">{t.duration}</span>}
            </li>
          ))}
        </ol>
      </section>
    )}

    <!-- ── CRÉDITOS ─────────────────────────────────────────── -->
    {vinyl.credits && vinyl.credits.length > 0 && (
      <section class="credits">
        <h3>Créditos</h3>
        <ul class="credits-list">
          {vinyl.credits.map((c) => (
            <li class="credit-item">
              <span class="credit-icon">{creditIcon(c.role)}</span>
              <span class="credit-name">{c.name}</span>
              <span class="credit-role">{c.role}</span>
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- ── EMAIL CAPTURE ────────────────────────────────────── -->
    <section class="email-capture">
      <p class="email-capture-copy">Si querés saber cuándo llega un disco nuevo, dejá tu correo acá.</p>
      <script async data-uid="345b76391f" src="https://en-las-nubes-trepao.kit.com/345b76391f/index.js"></script>
    </section>

    <!-- ── RECOMENDACIONES ───────────────────────────────────── -->
    {related.length > 0 && (
      <section class="related">
        <h3 class="related-heading">Más de la colección · {vinyl.genero}</h3>
        <div class="related-grid">
          {related.map(v => (
            <a href={`/vinilos/${vinylSlug(v)}/`} class="related-card">
              {v.cover_url
                ? <img
                    class="related-cover"
                    src={v.cover_url}
                    alt={v.album}
                    width="160" height="160"
                    loading="lazy"
                  />
                : <div class="related-cover related-no-cover">🎵</div>
              }
              <div class="related-info">
                <span class="related-album">{v.album}</span>
                <span class="related-artist">{v.artista}</span>
                {v.anio && <span class="related-year">{v.anio}</span>}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

  </main>
</Base>

<style>
  /* ── Header (overlaid on hero) ───────────────────────────── */
  .site-header {
    position: absolute;
    top: 0; left: 0; right: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 32px;
    background: linear-gradient(to bottom, rgba(10,10,10,.7) 0%, transparent 100%);
  }
  .site-logo {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    color: #fff;
    text-decoration: none;
    letter-spacing: -.01em;
    text-shadow: 0 1px 6px rgba(0,0,0,.6);
  }
  .site-back {
    font-size: 0.78rem;
    color: rgba(255,255,255,.72);
    text-decoration: none;
    transition: color .15s;
  }
  .site-back:hover { color: #fff; }

  /* ── Hero ────────────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 400px;
    background: var(--bg);
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute; inset: 0;
    background-size: cover;
    background-position: center;
    filter: blur(44px) saturate(1.6);
    transform: scale(1.14);
    opacity: .36;
  }
  .hero-gradient {
    position: absolute; inset: 0;
    background: linear-gradient(
      to top,
      #0a0a0a 0%,
      rgba(10,10,10,.65) 55%,
      rgba(10,10,10,.15) 100%
    );
  }
  .hero-content {
    position: relative; z-index: 1;
    display: flex;
    align-items: flex-end;
    gap: 32px;
    padding: 90px 40px 40px;
    width: 100%;
    max-width: 960px;
    margin: 0 auto;
    box-sizing: border-box;
  }
  .hero-cover-wrap { flex-shrink: 0; }
  .hero-cover {
    width: 210px;
    height: 210px;
    border-radius: 8px;
    display: block;
    box-shadow: 0 20px 56px rgba(0,0,0,.85);
    object-fit: cover;
  }
  .hero-cover-placeholder {
    width: 210px; height: 210px;
    background: var(--bg3);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
  }
  .hero-info { flex: 1; min-width: 0; }
  .genre {
    font-size: 0.7rem;
    color: var(--v-acc);
    text-transform: uppercase;
    letter-spacing: .12em;
    margin-bottom: 10px;
  }
  .album {
    font-family: var(--font-display);
    font-size: clamp(1.7rem, 3.8vw, 2.8rem);
    font-weight: 700;
    line-height: 1.08;
    color: #fff;
    margin-bottom: 10px;
    text-shadow: 0 2px 10px rgba(0,0,0,.5);
  }
  .artist {
    font-size: 1rem;
    font-weight: 400;
    color: rgba(255,255,255,.68);
    margin-bottom: 24px;
  }
  .hero-links { display: flex; gap: 10px; flex-wrap: wrap; }
  .btn {
    padding: 8px 18px;
    border-radius: 8px;
    font-size: 0.82rem;
    font-weight: 600;
    text-decoration: none;
    transition: opacity .15s, transform .1s;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .btn:hover { opacity: .85; transform: translateY(-1px); }
  .btn-discogs { background: var(--v-acc); color: #fff; }

  /* ── Page body ───────────────────────────────────────────── */
  .page {
    max-width: 900px;
    margin: 0 auto;
    padding: 52px 32px 80px;
  }

  /* ── Notas editoriales ───────────────────────────────────── */
  .notes-section {
    margin-bottom: 52px;
    border-left: 3px solid var(--v-acc);
    padding-left: 28px;
  }
  .notes-label {
    display: block;
    font-size: 0.64rem;
    color: var(--v-acc);
    text-transform: uppercase;
    letter-spacing: .15em;
    margin-bottom: 16px;
  }
  .notes-mark {
    display: block;
    font-size: 3.5rem;
    color: rgba(192,57,43,.22);
    line-height: .8;
    margin-bottom: 16px;
    font-family: Georgia, serif;
  }
  .notes-lead {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--text);
    line-height: 1.75;
    margin-bottom: 1.1em;
  }
  .notes-p {
    font-family: var(--font-display);
    font-size: 0.98rem;
    color: var(--text2);
    line-height: 1.82;
    margin-bottom: 1em;
  }

  /* ── Meta + Spotify ──────────────────────────────────────── */
  .meta-spotify-wrap {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-bottom: 52px;
    align-items: start;
  }
  .meta {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 8px 20px;
    font-size: 0.83rem;
    padding: 16px 20px;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: var(--r);
    align-self: start;
  }
  .meta dt { color: var(--text3); }
  .meta dd { color: var(--text); }
  .spotify-embed {
    border-radius: 12px;
    overflow: hidden;
  }
  .spotify-embed iframe {
    display: block;
    border-radius: 12px;
  }

  /* ── Tracklist ───────────────────────────────────────────── */
  .tracklist {
    margin-bottom: 52px;
    border-top: 1px solid var(--border);
    padding-top: 28px;
  }
  .tracklist h3 {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: .13em;
    color: var(--text3);
    margin-bottom: 16px;
  }
  .tracklist ol { list-style: none; }
  .tracklist li {
    display: grid;
    grid-template-columns: 2.5rem 1fr auto;
    gap: 8px;
    align-items: baseline;
    padding: 8px 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.83rem;
    transition: background .1s;
  }
  .tracklist li:hover {
    background: var(--bg2);
    margin: 0 -8px;
    padding: 8px;
    border-radius: 4px;
  }
  .track-pos { color: var(--text3); font-variant-numeric: tabular-nums; }
  .track-title { color: var(--text); }
  .track-dur { color: var(--text3); font-variant-numeric: tabular-nums; }

  /* ── Créditos ───────────────────────────────────────────── */
  .credits {
    margin-bottom: 52px;
    border-top: 1px solid var(--border);
    padding-top: 28px;
  }
  .credits h3 {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: .13em;
    color: var(--text3);
    margin-bottom: 16px;
  }
  .credits-list { list-style: none; }
  .credit-item {
    display: grid;
    grid-template-columns: 1.8rem 1fr auto;
    gap: 8px;
    align-items: baseline;
    padding: 7px 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.82rem;
  }
  .credit-icon { font-size: 0.9rem; line-height: 1; }
  .credit-name { color: var(--text); font-weight: 500; }
  .credit-role { color: var(--text3); font-size: 0.72rem; text-align: right; }

  /* ── Recomendaciones ─────────────────────────────────────── */
  .related {
    border-top: 1px solid var(--border);
    padding-top: 32px;
  }
  .related-heading {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: .13em;
    color: var(--text3);
    margin-bottom: 20px;
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .related-card {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: transform .2s;
    cursor: pointer;
  }
  .related-card:hover { transform: translateY(-4px); }
  .related-cover {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 6px;
    display: block;
    box-shadow: 0 6px 20px rgba(0,0,0,.55);
    transition: box-shadow .2s;
  }
  .related-card:hover .related-cover {
    box-shadow: 0 10px 30px rgba(0,0,0,.7);
  }
  .related-no-cover {
    width: 100%;
    aspect-ratio: 1;
    background: var(--bg3);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
  }
  .related-info { display: flex; flex-direction: column; gap: 3px; }
  .related-album {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.3;
  }
  .related-artist { font-size: 0.7rem; color: var(--text2); }
  .related-year   { font-size: 0.65rem; color: var(--text3); }

  /* ── Email capture ──────────────────────────────────────── */
  .email-capture {
    border-top: 1px solid var(--border);
    padding-top: 40px;
    margin-bottom: 52px;
    text-align: center;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }
  .email-capture-copy {
    font-size: 0.88rem;
    color: var(--text2);
    margin-bottom: 20px;
    font-family: var(--font-display);
    font-style: italic;
  }
  /* Contener el iframe/widget de Kit */
  .email-capture > script + * ,
  .email-capture [data-uid] {
    max-width: 100% !important;
  }

  /* ── Mobile ──────────────────────────────────────────────── */
  @media (max-width: 680px) {
    .site-header { padding: 14px 20px; }
    .hero { min-height: 340px; }
    .hero-content {
      flex-direction: column;
      align-items: flex-start;
      padding: 72px 20px 28px;
      gap: 16px;
    }
    .hero-cover { width: 130px; height: 130px; }
    .hero-cover-placeholder { width: 130px; height: 130px; }
    .album { font-size: 1.55rem; }
    .page { padding: 36px 20px 60px; }
    .notes-section { padding-left: 18px; }
    .meta-spotify-wrap { grid-template-columns: 1fr; }
    .related-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
  }
</style>
