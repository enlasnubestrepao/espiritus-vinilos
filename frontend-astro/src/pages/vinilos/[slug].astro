---
import Base from '../../layouts/Base.astro'
import { vinylSlug } from '../../utils/slugify.js'
import '../../styles/global.css'

export async function getStaticPaths() {
  const apiUrl = import.meta.env.VITE_API_URL || 'https://espiritus-vinilos.onrender.com'
  const res = await fetch(`${apiUrl}/api/vinyls/`)
  if (!res.ok) return []
  const vinyls = await res.json()

  return vinyls.map((vinyl, index) => ({
    params: { slug: vinylSlug(vinyl) },
    props: { vinyl, index },
  }))
}

const { vinyl } = Astro.props

const title = `${vinyl.artista} — ${vinyl.album} | En Las Nubes Trepao`
const description = [
  vinyl.genero,
  vinyl.anio,
  vinyl.pais,
  vinyl.sello,
].filter(Boolean).join(' · ')

const ogImage = vinyl.cover_url || 'https://enlasnubestrepao.com/og-image.jpg'
---

<Base
  title={title}
  description={description || undefined}
  ogImage={ogImage}
  ogType="music.album"
>
  <!-- Header mínimo con identidad del sitio -->
  <header class="site-header">
    <a href="/" class="site-logo">En Las Nubes Trepao</a>
    <a href="/" class="site-back">← Volver al catálogo</a>
  </header>

  <main class="page">
    <article class="vinyl">
      <div class="cover-wrap">
        {vinyl.cover_url
          ? <img class="cover" src={vinyl.cover_url} alt={`${vinyl.album} — ${vinyl.artista}`} width="300" height="300" loading="eager" />
          : <div class="cover-placeholder">🎵</div>
        }
      </div>

      <div class="info">
        <p class="genre">{vinyl.genero}{vinyl.agrupador ? ` · ${vinyl.agrupador}` : ''}</p>
        <h1 class="album">{vinyl.album}</h1>
        <h2 class="artist">{vinyl.artista}</h2>

        <dl class="meta">
          {vinyl.anio    && <><dt>Año</dt><dd>{vinyl.anio}</dd></>}
          {vinyl.pais    && <><dt>País</dt><dd>{vinyl.pais}</dd></>}
          {vinyl.sello   && <><dt>Sello</dt><dd>{vinyl.sello}{vinyl.pais_sello ? ` (${vinyl.pais_sello})` : ''}</dd></>}
          {vinyl.cat_num && <><dt>Catálogo</dt><dd>{vinyl.cat_num}</dd></>}
          {vinyl.origen  && <><dt>Origen</dt><dd>{vinyl.origen}</dd></>}
        </dl>

        <div class="links">
          {vinyl.url && (
            <a class="btn btn-discogs" href={vinyl.url} target="_blank" rel="noopener">🔗 Discogs</a>
          )}
          {vinyl.spotify_id && (
            <a class="btn btn-spotify" href={`https://open.spotify.com/album/${vinyl.spotify_id}`} target="_blank" rel="noopener">▶ Spotify</a>
          )}
        </div>

        {vinyl.notes && (
          <div class="notes">
            <span class="notes-label">Notas editoriales</span>
            <span class="notes-mark">❝</span>
            <p class="notes-text">{vinyl.notes}</p>
          </div>
        )}
      </div>
    </article>

    {vinyl.tracks && vinyl.tracks.length > 0 && (
      <section class="tracklist">
        <h3>Tracklist</h3>
        <ol>
          {vinyl.tracks.map((t) => (
            <li>
              <span class="track-pos">{t.position}</span>
              <span class="track-title">{t.title}</span>
              {t.duration && <span class="track-dur">{t.duration}</span>}
            </li>
          ))}
        </ol>
      </section>
    )}
  </main>
</Base>

<style>
  /* ── Header ────────────────────────────────────────────────────────── */
  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 24px;
    border-bottom: 1px solid var(--border);
    background: var(--bg2);
  }
  .site-logo {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    text-decoration: none;
    letter-spacing: -.01em;
  }
  .site-back {
    font-size: 0.8rem;
    color: var(--text2);
    text-decoration: none;
    transition: color .15s;
  }
  .site-back:hover { color: var(--text); }

  /* ── Layout ─────────────────────────────────────────────────────────── */
  .page {
    max-width: 900px;
    margin: 0 auto;
    padding: 40px 24px 80px;
  }

  .vinyl {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 40px;
    align-items: start;
  }

  @media (max-width: 680px) {
    .vinyl { grid-template-columns: 1fr; }
    .cover-wrap { max-width: 220px; margin: 0 auto; }
  }

  /* ── Cover ───────────────────────────────────────────────────────────── */
  .cover-wrap { position: sticky; top: 24px; }

  .cover {
    width: 100%;
    height: auto;
    border-radius: 8px;
    display: block;
    box-shadow: 0 12px 40px rgba(0,0,0,.7);
  }

  .cover-placeholder {
    width: 100%;
    aspect-ratio: 1;
    background: var(--bg3);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    color: var(--text3);
  }

  /* ── Info ────────────────────────────────────────────────────────────── */
  .genre {
    font-size: 0.72rem;
    color: var(--v-acc);
    text-transform: uppercase;
    letter-spacing: .1em;
    margin-bottom: 10px;
  }

  .album {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 4vw, 2.6rem);
    font-weight: 700;
    line-height: 1.1;
    color: var(--text);
    margin-bottom: 8px;
  }

  .artist {
    font-size: 1.05rem;
    font-weight: 400;
    color: var(--text2);
    margin-bottom: 28px;
  }

  /* ── Meta ────────────────────────────────────────────────────────────── */
  .meta {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 7px 20px;
    font-size: 0.83rem;
    margin-bottom: 28px;
    padding: 16px;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: var(--r);
  }
  .meta dt { color: var(--text3); }
  .meta dd { color: var(--text); }

  /* ── Links ───────────────────────────────────────────────────────────── */
  .links { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 28px; }

  .btn {
    padding: 8px 18px;
    border-radius: 8px;
    font-size: 0.82rem;
    font-weight: 600;
    text-decoration: none;
    transition: opacity .15s, transform .1s;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .btn:hover { opacity: .85; transform: translateY(-1px); }
  .btn-discogs { background: var(--v-acc); color: #fff; }
  .btn-spotify { background: #1db954; color: #000; }

  /* ── Notas editoriales ───────────────────────────────────────────────── */
  .notes {
    border: 1px solid rgba(192,57,43,.25);
    border-left: 3px solid var(--v-acc);
    padding: 16px 20px;
    background: linear-gradient(135deg, rgba(192,57,43,.08) 0%, rgba(0,0,0,0) 70%);
    border-radius: 0 var(--r) var(--r) 0;
  }
  .notes-label {
    display: block;
    font-size: 0.68rem;
    color: var(--v-acc);
    text-transform: uppercase;
    letter-spacing: .12em;
    margin-bottom: 8px;
  }
  .notes-mark {
    display: block;
    font-size: 2.2rem;
    color: rgba(192,57,43,.25);
    line-height: 1;
    margin-bottom: 8px;
  }
  .notes-text {
    font-size: 0.9rem;
    color: var(--text2);
    line-height: 1.75;
    white-space: pre-wrap;
  }

  /* ── Tracklist ───────────────────────────────────────────────────────── */
  .tracklist {
    margin-top: 48px;
    border-top: 1px solid var(--border);
    padding-top: 28px;
  }
  .tracklist h3 {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--text3);
    margin-bottom: 16px;
  }
  .tracklist ol { list-style: none; }
  .tracklist li {
    display: grid;
    grid-template-columns: 2.5rem 1fr auto;
    gap: 8px;
    align-items: baseline;
    padding: 8px 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.83rem;
    transition: background .1s;
  }
  .tracklist li:hover { background: var(--bg2); margin: 0 -8px; padding: 8px; border-radius: 4px; }
  .track-pos { color: var(--text3); font-variant-numeric: tabular-nums; }
  .track-title { color: var(--text); }
  .track-dur { color: var(--text3); font-variant-numeric: tabular-nums; }
</style>
