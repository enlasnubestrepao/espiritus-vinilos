---
import Base from '../../layouts/Base.astro'
import { vinylSlug } from '../../utils/slugify.js'

export async function getStaticPaths() {
  const apiUrl = import.meta.env.VITE_API_URL || 'https://espiritus-vinilos.onrender.com'
  const res = await fetch(`${apiUrl}/api/vinyls/`)
  if (!res.ok) return []
  const vinyls = await res.json()

  return vinyls.map((vinyl, index) => ({
    params: { slug: vinylSlug(vinyl) },
    props: { vinyl, index },
  }))
}

const { vinyl, index } = Astro.props

const title = `${vinyl.artista} — ${vinyl.album} | En Las Nubes Trepao`
const description = [
  vinyl.genero,
  vinyl.anio,
  vinyl.pais,
  vinyl.sello,
].filter(Boolean).join(' · ')

const ogImage = vinyl.cover_url || 'https://enlasnubestrepao.com/og-image.jpg'
const canonicalPath = `/vinilos/${vinylSlug(vinyl)}/`
---

<Base
  title={title}
  description={description || undefined}
  ogImage={ogImage}
  ogType="music.album"
>
  <main class="page">
    <a class="back" href="/">&larr; Volver al catálogo</a>

    <article class="vinyl">
      <div class="cover-wrap">
        {vinyl.cover_url && (
          <img
            class="cover"
            src={vinyl.cover_url}
            alt={`Portada de ${vinyl.album} por ${vinyl.artista}`}
            width="300"
            height="300"
            loading="eager"
          />
        )}
      </div>

      <div class="info">
        <p class="genre">{vinyl.genero}{vinyl.agrupador ? ` · ${vinyl.agrupador}` : ''}</p>
        <h1 class="album">{vinyl.album}</h1>
        <h2 class="artist">{vinyl.artista}</h2>

        <dl class="meta">
          {vinyl.anio && <><dt>Año</dt><dd>{vinyl.anio}</dd></>}
          {vinyl.pais && <><dt>País</dt><dd>{vinyl.pais}</dd></>}
          {vinyl.sello && <><dt>Sello</dt><dd>{vinyl.sello}{vinyl.pais_sello ? ` (${vinyl.pais_sello})` : ''}</dd></>}
          {vinyl.cat_num && <><dt>Catálogo</dt><dd>{vinyl.cat_num}</dd></>}
          {vinyl.origen && <><dt>Origen</dt><dd>{vinyl.origen}</dd></>}
        </dl>

        <div class="links">
          {vinyl.url && (
            <a class="btn btn-discogs" href={vinyl.url} target="_blank" rel="noopener">
              Discogs
            </a>
          )}
          {vinyl.spotify_id && (
            <a
              class="btn btn-spotify"
              href={`https://open.spotify.com/album/${vinyl.spotify_id}`}
              target="_blank"
              rel="noopener"
            >
              Spotify
            </a>
          )}
        </div>

        {vinyl.notes && (
          <div class="notes">
            <span class="notes-label">Notas editoriales</span>
            <span class="notes-mark">❝</span>
            <p class="notes-text">{vinyl.notes}</p>
          </div>
        )}
      </div>
    </article>

    {vinyl.tracks && vinyl.tracks.length > 0 && (
      <section class="tracklist">
        <h3>Tracklist</h3>
        <ol>
          {vinyl.tracks.map((t) => (
            <li>
              <span class="track-pos">{t.position}</span>
              <span class="track-title">{t.title}</span>
              {t.duration && <span class="track-dur">{t.duration}</span>}
            </li>
          ))}
        </ol>
      </section>
    )}
  </main>
</Base>

<style>
  .page {
    max-width: 860px;
    margin: 0 auto;
    padding: 32px 20px 60px;
    color: var(--text);
  }

  .back {
    display: inline-block;
    color: var(--text2);
    text-decoration: none;
    font-size: 0.85rem;
    margin-bottom: 32px;
    transition: color .15s;
  }
  .back:hover { color: var(--text); }

  .vinyl {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 36px;
    align-items: start;
  }

  @media (max-width: 680px) {
    .vinyl { grid-template-columns: 1fr; }
    .cover-wrap { max-width: 260px; }
  }

  .cover-wrap {
    position: sticky;
    top: 24px;
  }

  .cover {
    width: 100%;
    height: auto;
    border-radius: 6px;
    display: block;
    box-shadow: 0 8px 32px rgba(0,0,0,.5);
  }

  .genre {
    font-size: 0.75rem;
    color: var(--v-acc);
    text-transform: uppercase;
    letter-spacing: .08em;
    margin-bottom: 8px;
  }

  .album {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 6px;
  }

  .artist {
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--text2);
    margin-bottom: 24px;
  }

  .meta {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 6px 16px;
    font-size: 0.85rem;
    margin-bottom: 24px;
  }
  .meta dt { color: var(--text3); }
  .meta dd { color: var(--text); }

  .links { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 28px; }

  .btn {
    padding: 7px 16px;
    border-radius: 6px;
    font-size: 0.82rem;
    font-weight: 600;
    text-decoration: none;
    transition: opacity .15s;
  }
  .btn:hover { opacity: .8; }
  .btn-discogs { background: var(--v-acc); color: #fff; }
  .btn-spotify { background: #1db954; color: #000; }

  .notes {
    border-left: 2px solid rgba(192,57,43,.4);
    padding: 12px 0 12px 16px;
    background: linear-gradient(90deg, rgba(192,57,43,.07) 0%, transparent 100%);
    border-radius: 0 6px 6px 0;
  }
  .notes-label {
    display: block;
    font-size: 0.7rem;
    color: var(--v-acc);
    text-transform: uppercase;
    letter-spacing: .1em;
    margin-bottom: 6px;
  }
  .notes-mark {
    display: block;
    font-size: 2rem;
    color: rgba(192,57,43,.3);
    line-height: 1;
    margin-bottom: 4px;
  }
  .notes-text {
    font-size: 0.9rem;
    color: var(--text2);
    line-height: 1.65;
    white-space: pre-wrap;
  }

  .tracklist {
    margin-top: 40px;
    border-top: 1px solid var(--border);
    padding-top: 24px;
  }
  .tracklist h3 {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--text3);
    margin-bottom: 16px;
  }
  .tracklist ol { list-style: none; }
  .tracklist li {
    display: grid;
    grid-template-columns: 2.5rem 1fr auto;
    gap: 8px;
    align-items: baseline;
    padding: 6px 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.85rem;
  }
  .track-pos { color: var(--text3); }
  .track-title { color: var(--text); }
  .track-dur { color: var(--text3); font-variant-numeric: tabular-nums; }
</style>
